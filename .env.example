# Copy this file to .env and fill in your credentials.
# cp .env.example .env

# Required: OpenAI-compatible API credentials
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here

# Optional: model name (default: claude-sonnet-4-6)
# MODEL_NAME=gpt-4o

# ============================================================================
# VLM 图表分析配置（可选）
# ============================================================================
# 启用 VLM 图表分析
ENABLE_VLM_ANALYSIS=false

# VLM 模型配置（支持 Qwen、GPT-4o、Claude 等）
# 分类模型（轻量级）：判断图表类型和重要性
VLM_CLASSIFY_MODEL=qwen3.5-flash

# 分析模型（强模型）：深度分析图表内容
VLM_MODEL=qwen3.5-plus

# VLM API 配置（默认使用上方的 OPENAI_API_BASE 和 OPENAI_API_KEY）
# 如需单独配置，取消下方注释：
# VLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# VLM_API_KEY=your-qwen-api-key

# 图表分析限制
MAX_FIGURES_PER_PAPER=5  # 每篇论文最多分析几张图
